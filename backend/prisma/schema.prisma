generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  role         String        @default("PLAYER")
  createdAt    DateTime      @default(now())
  wallet       Wallet?
  transactions Transaction[]
  gameRounds   GameRound[]
}

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Int      @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  amount       Int
  balanceAfter Int
  type         String
  description  String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model GameRound {
  id        Int      @id @default(autoincrement())
  userId    Int
  game      String
  stake     Int
  choice    Int
  drawn     Int
  won       Boolean
  delta     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}
